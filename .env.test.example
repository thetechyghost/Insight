# Integration test environment configuration
# Copy to .env.test and fill in values

# Target: "dev" for local Convex dev deployment, "preprod" for staging
TEST_TARGET=dev

# Convex deployment URLs
CONVEX_URL=
CONVEX_PREPROD_URL=

# Test API key for seed/cleanup endpoints (must match ENABLE_TEST_ENDPOINTS env var on Convex)
TEST_API_KEY=

# Future: TimescaleDB, Azure Functions
# TIMESCALE_URL=postgresql://test:test@localhost:5433/insight_test
# AZURE_FUNCTIONS_URL=http://localhost:7071
